# Port exposed on the Mac.
APP_PORT=8000

# Mounted local or external storage path on the Mac.
# Example: /Volumes/SAMSUNG/ck/Picture
J3_MOUNT_PATH=/Users/kidchang/Desktop/ck/privacy/local-media-vault/tmp/storage

# Set this to the Mac Wi-Fi URL for mobile QR output.
# Example: APP_BASE_URL=http://192.168.25.12:8000
APP_BASE_URL=

# Change these before first run. They are only used to bootstrap a new DB.
ADMIN_PASSWORD=change-this-admin-password
LCK_PASSWORD=change-this-lck-password
CSE_PASSWORD=change-this-cse-password

SESSION_COOKIE_SECURE=false

# Per-file upload limit. Default is 2 GiB.
MAX_FILE_SIZE_BYTES=2147483648
